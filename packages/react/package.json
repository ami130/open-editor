{
  "name": "@open-editor-hq/react",
  "version": "1.1.0",
  "private": false,
  "description": "Official React wrapper for Open Editor — idiomatic <OpenEditor /> component",
  "type": "module",
  "license": "MIT",
  "author": "Open Editor contributors",
  "keywords": ["rich-text-editor", "wysiwyg", "react", "react-component", "open-editor"],
  "main": "./dist/open-editor-react.min.cjs",
  "module": "./dist/open-editor-react.min.js",
  "types": "./index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/open-editor-react.min.js",
      "require": "./dist/open-editor-react.min.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "index.d.ts"],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "test": "vitest run",
    "prepack": "rollup -c rollup.config.js",
    "prepublishOnly": "rollup -c rollup.config.js"
  },
  "peerDependencies": {
    "@open-editor-hq/core": ">=1.1.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@open-editor-hq/core": "workspace:*",
    "@rollup/plugin-terser": "^1.0.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "4.62.0",
    "vitest": "1.6.1"
  }
}
