{
  "name": "openeditor-text-vue",
  "version": "1.1.0",
  "private": false,
  "description": "Official Vue 3 wrapper for Open Editor — v-model component + useOpenEditor composable",
  "type": "module",
  "license": "MIT",
  "author": "Open Editor contributors",
  "keywords": ["rich-text-editor", "wysiwyg", "vue", "vue3", "open-editor"],
  "main": "./dist/open-editor-vue.min.cjs",
  "module": "./dist/open-editor-vue.min.js",
  "types": "./index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/open-editor-vue.min.js",
      "require": "./dist/open-editor-vue.min.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "index.d.ts"],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "test": "vitest run",
    "prepack": "rollup -c rollup.config.js",
    "prepublishOnly": "rollup -c rollup.config.js"
  },
  "peerDependencies": {
    "openeditor-text": ">=1.1.0",
    "vue": ">=3.3"
  },
  "devDependencies": {
    "openeditor-text": "workspace:*",
    "@rollup/plugin-terser": "^1.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "29.1.1",
    "rollup": "4.62.0",
    "vitest": "1.6.1",
    "vue": "^3.5.13"
  }
}
